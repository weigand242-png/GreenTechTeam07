# Flip to "1" to switch the timeseries provider from static JSON to live SMARD + Open-Meteo.
LIVE_TIMESERIES=0

# Public German energy data — no key required.
SMARD_BASE_URL=https://www.smard.de/app/chart_data
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# Default fleet location used for the solar-radiation lookup (Frankfurt).
FLEET_LAT=50.11
FLEET_LON=8.65